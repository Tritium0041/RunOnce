<?xml version="1.0" encoding="utf-8"?>
<!--
    @file: View/Editor.xaml
    @date: 2026-03-09
-->
<Page
    x:Class="RunOnce.View.Editor"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent"
    NavigationCacheMode="Required">

    <Page.Resources>
        <SolidColorBrush x:Key="TextControlBackground" Color="Transparent"/>
        <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="Transparent"/>
        <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="Transparent"/>
        <SolidColorBrush x:Key="TextControlBackgroundReadOnly" Color="Transparent"/>
        <SolidColorBrush x:Key="TextControlBackgroundDisabled" Color="Transparent"/>

        <SolidColorBrush x:Key="TextControlBorderBrush" Color="Transparent"/>
        <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="Transparent"/>
        <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="Transparent"/>
        <SolidColorBrush x:Key="TextControlBorderBrushDisabled" Color="Transparent"/>

        <Thickness x:Key="TextControlBorderThemeThickness">0</Thickness>
        <Thickness x:Key="TextControlBorderThemeThicknessFocused">0</Thickness>
    </Page.Resources>

    <Page.KeyboardAccelerators>
        <KeyboardAccelerator Key="Enter" Modifiers="Control" Invoked="ExecuteAccelerator_Invoked"/>
    </Page.KeyboardAccelerators>

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 代码编辑器区域 -->
        <Grid Grid.Row="0">
            <RichEditBox
                x:Name="CodeEditor"
                AcceptsReturn="True"
                IsSpellCheckEnabled="False"
                TextWrapping="NoWrap"
                FontFamily="Cascadia Code, Cascadia Mono, Consolas, Courier New, monospace"
                FontSize="18"
                BorderThickness="0"
                CornerRadius="0"
                Padding="4,0,4,0"
                Background="Transparent"
                BorderBrush="Transparent"
                ScrollViewer.HorizontalScrollBarVisibility="Auto"
                ScrollViewer.HorizontalScrollMode="Enabled"
                ScrollViewer.VerticalScrollBarVisibility="Auto"
                ScrollViewer.VerticalScrollMode="Enabled"
                SelectionChanged="CodeEditor_SelectionChanged"
                TextChanged="CodeEditor_TextChanged"
                PreviewKeyDown="CodeEditor_PreviewKeyDown"
                PointerPressed="CodeEditor_PointerPressed"
                PointerReleased="CodeEditor_PointerReleased"
                PointerCanceled="CodeEditor_PointerCanceled"
                PointerCaptureLost="CodeEditor_PointerCaptureLost"
                LostFocus="CodeEditor_LostFocus">
                <RichEditBox.Resources>
                    <Thickness x:Key="TextControlBorderThemeThicknessFocused">0</Thickness>
                </RichEditBox.Resources>
            </RichEditBox>

            <!-- 占位提示文案 -->
            <TextBlock
                x:Name="PlaceholderText"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                IsHitTestVisible="False"
                Opacity="0.35"
                FontSize="16"
                FontFamily="Cascadia Code, Cascadia Mono, Consolas, Courier New, monospace"
                Visibility="Visible"/>
        </Grid>

        <!-- 底部状态栏 -->
        <Grid
            Grid.Row="1"
            Background="Transparent"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0"
            Padding="4,0,12,0"
            Height="28">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- 语言指示器按钮 -->
            <Button
                x:Name="LanguageButton"
                Grid.Column="0"
                Style="{ThemeResource SubtleButtonStyle}"
                Padding="8,2"
                VerticalAlignment="Stretch"
                Click="LanguageButton_Click">
                <TextBlock
                    Text="{x:Bind ViewModel.DetectedLanguageDisplay, Mode=OneWay}"
                    Style="{ThemeResource CaptionTextBlockStyle}"
                    VerticalAlignment="Center"/>
            </Button>

            <!-- 行列位置信息 -->
            <TextBlock
                Grid.Column="2"
                Text="{x:Bind ViewModel.PositionDisplay, Mode=OneWay}"
                Style="{ThemeResource CaptionTextBlockStyle}"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                VerticalAlignment="Center"/>
        </Grid>
    </Grid>
</Page>
    